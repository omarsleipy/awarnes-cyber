# Database — use asyncpg driver for async SQLAlchemy
# Either DB_URL or DATABASE_URL is accepted. With Docker Compose (port 5433), use:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/cyberaware
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cyberaware

# JWT (use a long random secret in production)
JWT_SECRET=change-me-in-production-use-long-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — comma-separated origins (browser Origin header). Must include every frontend URL.
# Local Vite + temporary Vercel deploy (replace with your *.vercel.app URL):
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,https://your-app.vercel.app

# SMTP (for sending exam passwords and notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=CyberAware Platform
SMTP_USE_TLS=true
SMTP_MOCK_MODE=true

# App URLs for email links and phishing tracking
APP_BASE_URL=http://localhost:8000
# Links in emails / redirects — use your Vercel URL in production.
FRONTEND_BASE_URL=http://localhost:8080

# LDAP / SSO (stub integration)
LDAP_SERVER=ldap://ad.example.com
LDAP_PORT=389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(objectClass=person)
LDAP_USE_SSL=false
