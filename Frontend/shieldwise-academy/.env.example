# =============================================================================
# CyberAware frontend — environment variables (Vite)
# =============================================================================
#
# VITE_API_URL (required for production builds)
#   Full base URL of the FastAPI app INCLUDING the /api prefix.
#   Example: https://your-backend.example.com/api
#
#   • Local: copy this file to .env and use the default below, or set explicitly.
#   • Vercel: Project → Settings → Environment Variables → add VITE_API_URL for
#     Production (and Preview if needed). Redeploy after changing — Vite inlines
#     env at build time.
#
#   Do not commit .env (secrets / machine-specific). Commit .env.example only.
#
# =============================================================================

VITE_API_URL=http://localhost:8000/api
